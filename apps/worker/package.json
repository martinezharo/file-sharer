{
  "name": "@file-sharer/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply file-sharer-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply file-sharer-db --remote"
  },
  "dependencies": {
    "@file-sharer/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.103.0"
  }
}
