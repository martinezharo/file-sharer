{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["vite/client", "vite-plugin-pwa/client"],
    "noEmit": true
  },
  // The service worker is typechecked separately with the WebWorker lib
  // (tsconfig.sw.json) — the DOM and WebWorker libs cannot coexist.
  "include": ["src"],
  "exclude": ["src/sw.ts", "src/sw"]
}
