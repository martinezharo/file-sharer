{
  "name": "file-sharer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n worker,web -c blue,green \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:worker": "pnpm --filter @file-sharer/worker dev",
    "dev:web": "pnpm --filter @file-sharer/web dev",
    "build": "pnpm --filter @file-sharer/web build",
    "deploy": "pnpm --filter @file-sharer/web build && pnpm --filter @file-sharer/worker deploy",
    "db:migrate:local": "pnpm --filter @file-sharer/worker db:migrate:local",
    "db:migrate:remote": "pnpm --filter @file-sharer/worker db:migrate:remote",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
  }
}
